# Cloudflare R2 credentials for SQLite DB storage.
# Copy this file to .env for local runs. Never commit .env.

# Cloudflare account ID, visible in the Cloudflare dashboard URL.
R2_ACCOUNT_ID=your_cloudflare_account_id

# R2 bucket name that stores the SQLite databases.
R2_BUCKET=your-r2-bucket-name

# R2 API token access key with object read/write permissions for the bucket.
R2_ACCESS_KEY_ID=your_r2_access_key_id

# R2 API token secret key.
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Optional object prefix inside the bucket. Leave blank to store at db/nav.db etc.
R2_PREFIX=indian-mf-nav-history

# Optional custom endpoint. Usually not needed.
# R2_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com

# Optional signing region. Cloudflare R2 defaults to auto.
R2_REGION=auto
